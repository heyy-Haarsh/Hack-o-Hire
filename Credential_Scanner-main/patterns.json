        "category": "payment"
    },
    "amex_card": {
        "regex": "\\b3[47][0-9]{2}[\\s-]?[0-9]{6}[\\s-]?[0-9]{5}\\b",
        "desc": "American Express card number",
        "risk": "Critical",
        "category": "payment"
    },
    "rupay_card": {
        "regex": "\\b6[0-9]{3}[\\s-]?[0-9]{4}[\\s-]?[0-9]{4}[\\s-]?[0-9]{4}\\b",
