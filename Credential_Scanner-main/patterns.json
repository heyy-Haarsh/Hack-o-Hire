        "category": "auth_code"
    },
    "uk_account_number": {
        "regex": "\\b[0-9]{8}\\b",
        "risk": "High",
        "desc": "UK bank account number",
        "category": "banking"
    },
    "pin_number": {
        "regex": "(?i)\\bpin\\s*[:=]\\s*[0-9]{4,6}\\b",
