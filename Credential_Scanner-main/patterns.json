        "desc": "Slack API token",
        "category": "dev_token"
    },
    "verification_code": {
        "regex": "(?i)(your\\s+)?(verification|security|auth)\\s+(code|number)\\s+(is|:)\\s*[0-9]{4,8}",
        "risk": "High",
