        "risk": "Critical",
        "category": "identity"
    },
    "pan_card": {
        "regex": "\\b[A-Z]{5}[0-9]{4}[A-Z]{1}\\b",
        "desc": "Indian PAN card number",
        "risk": "Critical",
        "category": "identity"
    },
    "upi_id": {
        "regex": "\\b[\\w.+-]+@[\\w]+\\b(?=.*upi|.*pay|.*bhim)",
